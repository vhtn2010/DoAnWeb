# =========================
# APP
# =========================
NODE_ENV=development
PORT=3000
API_PREFIX=/api

BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173


# =========================
# SUPABASE DATABASE
# Cloud PostgreSQL Database
# =========================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional for Supabase CLI migration workflow
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_POOLER_URL=
SUPABASE_DB_URL=
DB_AUTO_MIGRATE=false
DB_MIGRATE_STRICT=false
DB_SSL=true
# Set to false on local/dev machines that are behind a proxy or self-signed CA.
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=


# =========================
# JWT AUTH
# =========================
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=30m

JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_VERIFICATION_SECRET=
EMAIL_VERIFICATION_EXPIRES_IN_MINUTES=1440
PASSWORD_RESET_SECRET=
PASSWORD_RESET_EXPIRES_IN_MINUTES=30
CHANGE_EMAIL_SECRET=
CHANGE_EMAIL_EXPIRES_IN_MINUTES=30


# =========================
# PASSWORD HASH
# =========================
BCRYPT_SALT_ROUNDS=10


# =========================
# CLOUDINARY
# =========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=net-viet-travel
CLOUDINARY_REQUEST_TIMEOUT_MS=20000


# =========================
# SENDGRID MAIL
# =========================
SENDGRID_API_KEY=
SENDGRID_REQUEST_TIMEOUT_MS=20000
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Net Viet Travel


# =========================
# DIRECT PAYMENT
# Use DIRECT_PAYMENT_ENABLED_METHODS or individual *_ENABLED flags
# =========================
DIRECT_PAYMENT_ENABLED_METHODS=
DIRECT_PAYMENT_HOTLINE=

DIRECT_PAYMENT_CASH_AT_OFFICE_ENABLED=false
DIRECT_PAYMENT_CASH_AT_OFFICE_OFFICE_ADDRESS=
DIRECT_PAYMENT_CASH_AT_OFFICE_OFFICE_HOURS=
DIRECT_PAYMENT_CASH_AT_OFFICE_HOTLINE=
DIRECT_PAYMENT_CASH_AT_OFFICE_INSTRUCTIONS=

DIRECT_PAYMENT_MANUAL_BANK_TRANSFER_ENABLED=false
DIRECT_PAYMENT_MANUAL_BANK_TRANSFER_BANK_NAME=
DIRECT_PAYMENT_MANUAL_BANK_TRANSFER_ACCOUNT_NUMBER=
DIRECT_PAYMENT_MANUAL_BANK_TRANSFER_ACCOUNT_HOLDER=
DIRECT_PAYMENT_MANUAL_BANK_TRANSFER_BRANCH=
DIRECT_PAYMENT_MANUAL_BANK_TRANSFER_TRANSFER_CONTENT_TEMPLATE=
DIRECT_PAYMENT_MANUAL_BANK_TRANSFER_INSTRUCTIONS=

DIRECT_PAYMENT_STAFF_COLLECT_ENABLED=false
DIRECT_PAYMENT_STAFF_COLLECT_HOTLINE=
DIRECT_PAYMENT_STAFF_COLLECT_CONDITIONS=
DIRECT_PAYMENT_STAFF_COLLECT_INSTRUCTIONS=


# =========================
# RATE LIMIT
# 10 minutes = 600000 ms
# =========================
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_STORE=memory
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_KEY_PREFIX=net-viet-travel:rate-limit
PROFILE_CHANGE_PASSWORD_RATE_LIMIT_WINDOW_MS=600000
PROFILE_CHANGE_PASSWORD_RATE_LIMIT_MAX_REQUESTS=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=600000
AUTH_LOGIN_RATE_LIMIT_MAX_REQUESTS=10
AUTH_CHANGE_EMAIL_REQUEST_RATE_LIMIT_WINDOW_MS=600000
AUTH_CHANGE_EMAIL_REQUEST_RATE_LIMIT_MAX_REQUESTS=5
AUTH_FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MS=600000
AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX_REQUESTS=5
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=600000
AUTH_REGISTER_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RESEND_VERIFICATION_RATE_LIMIT_WINDOW_MS=600000
AUTH_RESEND_VERIFICATION_RATE_LIMIT_MAX_REQUESTS=5
AUTH_RESET_PASSWORD_RATE_LIMIT_WINDOW_MS=600000
AUTH_RESET_PASSWORD_RATE_LIMIT_MAX_REQUESTS=5


# =========================
# LOGGING
# =========================
LOG_LEVEL=debug
LOG_DIR=logs
ENABLE_DEMO_ROUTES=true
ENABLE_SUPABASE_TEST_ROUTE=true
